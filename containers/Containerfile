ARG RUST_IMAGE=docker.io/library/rust:1.97.1-bookworm@sha256:77fac8b98f9f46062bb680b6d25d5bcaabfc400143952ebc572e924bcbedc3fa
ARG RUST_VERSION=1.97.1
ARG RUST_COMMIT=8bab26f4f68e0e26f0bb7960be334d5b520ea452
ARG REDB_VERSION=4.1.0
ARG REDB_COMMIT=6ed1f981ba4deab0b2adbdd7bccb46ec409b2191
ARG ALIVE2_COMMIT=1d1bc4fe3135492a8c1166838c776530de479420
ARG DEBIAN_SNAPSHOT=20260713T000000Z
ARG BUILD_ENVIRONMENT_ID=857daf7a274f92fd8270b010e8856b4d1ea32c2e0fd3e1d9c012a9f3d623dab1

FROM ${RUST_IMAGE} AS pinned-bookworm

ARG DEBIAN_SNAPSHOT

RUN sed --in-place \
        -e "s|^URIs: http://deb.debian.org/debian$|URIs: http://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT}|" \
        -e "s|^URIs: http://deb.debian.org/debian-security$|URIs: http://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT}|" \
        /etc/apt/sources.list.d/debian.sources \
    && grep --quiet --fixed-strings \
        "URIs: http://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT}" \
        /etc/apt/sources.list.d/debian.sources \
    && grep --quiet --fixed-strings \
        "URIs: http://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT}" \
        /etc/apt/sources.list.d/debian.sources \
    && ! grep --quiet --fixed-strings \
        'URIs: http://deb.debian.org/' \
        /etc/apt/sources.list.d/debian.sources

FROM pinned-bookworm AS rustc-builder

ARG BUILD_ENVIRONMENT_ID

RUN apt-get -o Acquire::Check-Valid-Until=false update \
    && apt-get install --yes --no-install-recommends \
        cmake \
        ninja-build \
        python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/rust
COPY third_party/rust/ ./
COPY config/rust-git-commit-info ./git-commit-info
COPY config/rust-bootstrap.toml /etc/rust-bootstrap.toml
COPY optimizer/ /usr/src/optimizer/

# Mutable build outputs are scoped to the pinned native environment. The Cargo
# registry remains shared because locked crate downloads are checksum-verified.
RUN --mount=type=cache,id=ai-compiler-optimizer-rust-${BUILD_ENVIRONMENT_ID},target=/usr/src/rust/build \
    --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    set -eux; \
    rustc_source_id="$({ \
        printf 'build-environment:%s\n' "${BUILD_ENVIRONMENT_ID}"; \
        find . -path ./build -prune -o -type f -print0 \
            | LC_ALL=C sort -z \
            | xargs -0 -r sha256sum; \
        sha256sum /etc/rust-bootstrap.toml; \
    } | sha256sum | cut -d ' ' -f 1)"; \
    rustc_source_id_short="$(printf '%s' "${rustc_source_id}" | cut -c1-16)"; \
    ./x build \
        --config /etc/rust-bootstrap.toml \
        --set "build.description=ai-compiler-optimizer-${rustc_source_id_short}" \
        --stage 1 \
        library; \
    build_host="$(rustc --version --verbose | sed -n 's/^host: //p')"; \
    mkdir -p /opt/rust-custom; \
    cp -a "build/${build_host}/stage1/." /opt/rust-custom/; \
    cp -a "build/${build_host}/ci-llvm" /opt/llvm; \
    LLVM_CONFIG="build/${build_host}/ci-llvm/bin/llvm-config" \
        OUTPUT=/tmp/libaco_optimizer.so \
        /usr/src/optimizer/build.sh; \
    OPT="build/${build_host}/ci-llvm/bin/opt" \
        PLUGIN=/tmp/libaco_optimizer.so \
        LLVM_CONFIG="build/${build_host}/ci-llvm/bin/llvm-config" \
        /usr/src/optimizer/test.sh; \
    install --mode 0755 \
        /tmp/libaco_optimizer.so \
        /opt/rust-custom/lib/libaco_optimizer.so; \
    printf '%s\n' "${rustc_source_id}" > /opt/rust-custom/.compiler-build-id

FROM rustc-builder AS alive2-builder

ARG RUST_IMAGE
ARG ALIVE2_COMMIT
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

RUN apt-get -o Acquire::Check-Valid-Until=false update \
    && apt-get install --yes --no-install-recommends \
        libz3-dev \
        re2c \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/alive2
COPY third_party/alive2/ ./
COPY patches/alive2-llvm22.patch /tmp/alive2-llvm22.patch
COPY scripts/alive2-git-version.sh /usr/local/bin/alive2-git-version
COPY scripts/build-alive2-with-llvm-config.sh /usr/local/bin/build-alive2-with-llvm-config

RUN set -eux; \
    llvm_config=/opt/llvm/bin/llvm-config; \
    test -x "${llvm_config}"; \
    git apply --check /tmp/alive2-llvm22.patch; \
    git apply /tmp/alive2-llvm22.patch; \
    build-alive2-with-llvm-config \
        /usr/src/alive2 \
        /tmp/alive2-build \
        /opt/alive2 \
        "${llvm_config}"; \
    /opt/alive2/bin/alive --version 2>&1 \
        | grep --fixed-strings "version ${ALIVE2_COMMIT}"; \
    /opt/alive2/bin/alive-tv --help 2>&1 \
        | grep --fixed-strings "version ${ALIVE2_COMMIT}"

FROM alive2-builder AS proof-checker

ARG RUST_IMAGE
ARG ALIVE2_COMMIT
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

LABEL org.opencontainers.image.title="Alive2 proof checker" \
      org.opencontainers.image.description="Pinned Alive2 refinement checker for optimizer candidates" \
      org.opencontainers.image.base.name="${RUST_IMAGE}" \
      org.cberner-ai.ai-compiler-optimizer.alive2-commit="${ALIVE2_COMMIT}" \
      org.cberner-ai.ai-compiler-optimizer.debian-snapshot="${DEBIAN_SNAPSHOT}" \
      org.cberner-ai.ai-compiler-optimizer.build-environment-id="${BUILD_ENVIRONMENT_ID}"

COPY scripts/verify-alive2-proofs.sh /usr/local/bin/verify-alive2-proofs
COPY scripts/verify-alive2-negative-proofs.sh /usr/local/bin/verify-alive2-negative-proofs
COPY optimizer/proofs/ /opt/aco/proofs/
COPY tests/alive2/ /opt/aco/regressions/

RUN set -eux; \
    ln -s /opt/alive2/bin/alive /usr/local/bin/alive; \
    ln -s /opt/alive2/bin/alive-tv /usr/local/bin/alive-tv; \
    alive --version 2>&1 | grep --fixed-strings "version ${ALIVE2_COMMIT}"; \
    alive-tv --help 2>&1 | grep --fixed-strings "version ${ALIVE2_COMMIT}"; \
    verify-alive2-proofs /opt/aco/proofs; \
    verify-alive2-negative-proofs /opt/aco/regressions

ENTRYPOINT ["/usr/local/bin/verify-alive2-proofs"]
CMD ["/opt/aco/proofs"]

FROM pinned-bookworm AS toolchain

ARG RUST_IMAGE
ARG RUST_VERSION
ARG RUST_COMMIT
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

LABEL org.opencontainers.image.title="AI compiler optimizer custom Rust toolchain" \
      org.opencontainers.image.description="Stage-1 Rust 1.97.1 compiler with optional ACO optimization passes" \
      org.opencontainers.image.base.name="${RUST_IMAGE}" \
      org.cberner-ai.ai-compiler-optimizer.debian-snapshot="${DEBIAN_SNAPSHOT}" \
      org.cberner-ai.ai-compiler-optimizer.build-environment-id="${BUILD_ENVIRONMENT_ID}"

COPY --from=rustc-builder /opt/rust-custom/ /opt/rust-custom/
COPY scripts/with-compiler-variant.sh /usr/local/bin/with-compiler-variant
COPY scripts/rustc-with-aco-passes.sh /usr/local/bin/rustc-with-aco-passes
COPY scripts/write-compiler-artifact-manifest.sh /usr/local/bin/write-compiler-artifact-manifest
COPY tests/compiler-cache-regression.sh /usr/local/bin/compiler-cache-regression
COPY tests/compiler-cache-probe/ /opt/compiler-cache-probe/
COPY tests/toolchain_smoke.rs /tmp/toolchain_smoke.rs

ENV PATH="/opt/rust-custom/bin:/usr/local/cargo/bin:${PATH}" \
    RUSTUP_TOOLCHAIN=${RUST_VERSION}

RUN set -eux; \
    test -s /opt/rust-custom/.compiler-build-id; \
    test -s /opt/rust-custom/lib/libaco_optimizer.so; \
    write-compiler-artifact-manifest; \
    test -s /opt/rust-custom/.compiler-artifacts.tsv; \
    test -s /opt/rust-custom/.compiler-artifact-id; \
    test "$(/opt/rust-custom/bin/rustc --print sysroot)" = "/opt/rust-custom"; \
    /opt/rust-custom/bin/rustc --version | grep --fixed-strings "ai-compiler-optimizer"; \
    /opt/rust-custom/bin/rustc --version --verbose; \
    /opt/rust-custom/bin/rustc --version --verbose | grep --fixed-strings "commit-hash: ${RUST_COMMIT}"; \
    /opt/rust-custom/bin/rustc \
        --edition 2024 \
        -O \
        /tmp/toolchain_smoke.rs \
        -o /tmp/toolchain-smoke-baseline; \
    /tmp/toolchain-smoke-baseline; \
    ACO_OPTIMIZER_TRACE=1 /usr/local/bin/rustc-with-aco-passes \
        --edition 2024 \
        -O \
        /tmp/toolchain_smoke.rs \
        --emit=llvm-ir \
        -o /tmp/toolchain-smoke-optimized.ll \
        2> /tmp/aco-optimizer-trace; \
    ! grep --quiet --extended-regexp \
        'aco\.(midpoint|slice-cmp)\.' \
        /tmp/toolchain-smoke-optimized.ll; \
    ! grep --quiet --fixed-strings 'aco-keyhole:' /tmp/aco-optimizer-trace; \
    /usr/local/bin/rustc-with-aco-passes \
        --edition 2024 \
        -O \
        /tmp/toolchain_smoke.rs \
        -o /tmp/toolchain-smoke-optimized \
        2> /tmp/aco-optimizer-build-stderr; \
    test ! -s /tmp/aco-optimizer-build-stderr; \
    /tmp/toolchain-smoke-optimized; \
    rm \
        /tmp/aco-optimizer-build-stderr \
        /tmp/aco-optimizer-trace \
        /tmp/toolchain-smoke-baseline \
        /tmp/toolchain-smoke-optimized \
        /tmp/toolchain-smoke-optimized.ll \
        /tmp/toolchain_smoke.rs

# Cargo must remain fresh for unchanged inputs, while relevant compiler,
# driver, wrapper, or plugin changes must select a new variant target.
RUN compiler-cache-regression

CMD ["/usr/local/bin/rustc-with-aco-passes", "--version", "--verbose"]

FROM toolchain AS redb-builder

ARG RUST_IMAGE
ARG RUST_VERSION
ARG RUST_COMMIT
ARG REDB_VERSION
ARG REDB_COMMIT
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

RUN apt-get -o Acquire::Check-Valid-Until=false update \
    && apt-get install --yes --no-install-recommends \
        cmake \
        libclang-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/redb
COPY third_party/redb/ ./
COPY config/redb-Cargo.lock ./Cargo.lock
COPY tests/redb-ir-probe/ /usr/src/tests/redb-ir-probe/
COPY scripts/select-cargo-executable.sh /usr/local/bin/select-cargo-executable
COPY scripts/build-redb-benchmark.sh /usr/local/bin/build-redb-benchmark
COPY scripts/write-benchmark-provenance.sh /usr/local/bin/write-benchmark-provenance
COPY scripts/compare-redb-benchmarks.sh /usr/local/bin/compare-redb-benchmarks
COPY scripts/select-redb-benchmark-mode.sh /usr/local/bin/select-redb-benchmark-mode
COPY scripts/summarize-redb-build-metrics.sh /usr/local/bin/summarize-redb-build-metrics
COPY scripts/verify-redb-variant-traces.sh /usr/local/bin/verify-redb-variant-traces
COPY tools/monotonic-clock.c /tmp/monotonic-clock.c

# Compile and test both variants with the same custom rustc. Cargo comes from
# the pinned official image and is only the build orchestrator. The variant
# wrapper isolates target artifacts by compiler and pass-plugin identity.
RUN --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    --mount=type=cache,id=ai-compiler-optimizer-redb-target-${BUILD_ENVIRONMENT_ID},target=/usr/src/redb/target \
    set -eux; \
    test "$(/opt/rust-custom/bin/rustc --print sysroot)" = "/opt/rust-custom"; \
    cargo --version | grep --fixed-strings "cargo ${RUST_VERSION}"; \
    cc \
        -std=c11 \
        -O2 \
        -Wall \
        -Wextra \
        -Werror \
        /tmp/monotonic-clock.c \
        -o /usr/local/bin/aco-monotonic-clock; \
    with-compiler-variant baseline \
        cargo test --locked --package redb@4.1.0 --lib; \
    with-compiler-variant optimized \
        cargo test --locked --package redb@4.1.0 --lib; \
    mkdir -p /usr/src/third_party; \
    ln -s /usr/src/redb /usr/src/third_party/redb; \
    for probe_variant in baseline optimized; do \
        ACO_CARGO_TARGET_ROOT="/tmp/redb-${probe_variant}-ir-probe-target" \
        ACO_OPTIMIZER_TRACE=1 \
            with-compiler-variant "${probe_variant}" \
            cargo build \
                --locked \
                --offline \
                --release \
                --manifest-path /usr/src/tests/redb-ir-probe/Cargo.toml \
                2> "/tmp/redb-${probe_variant}-ir-probe-trace"; \
    done; \
    verify-redb-variant-traces \
        /tmp/redb-baseline-ir-probe-trace \
        /tmp/redb-optimized-ir-probe-trace; \
    rm -rf \
        /tmp/redb-baseline-ir-probe-target \
        /tmp/redb-baseline-ir-probe-trace \
        /tmp/redb-optimized-ir-probe-target \
        /tmp/redb-optimized-ir-probe-trace \
        /usr/src/third_party/redb; \
    mkdir -p /usr/local/share/ai-compiler-optimizer

ENV ACO_BUILD_METRICS_FILE=/usr/local/share/ai-compiler-optimizer/redb-build-metrics.tsv \
    ACO_CARGO_TARGET_ROOT=/tmp/aco-redb-measured-target

RUN --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    set -eux; \
    test ! -e "${ACO_CARGO_TARGET_ROOT}"; \
    build-redb-benchmark \
        baseline \
        /usr/local/bin/redb-benchmark-baseline; \
    rm -rf -- "${ACO_CARGO_TARGET_ROOT}"

RUN --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    set -eux; \
    test ! -e "${ACO_CARGO_TARGET_ROOT}"; \
    ACO_OPTIMIZER_TRACE=1 build-redb-benchmark \
        midpoint \
        /usr/local/bin/redb-benchmark-midpoint \
        2> /tmp/aco-redb-midpoint-trace; \
    grep --extended-regexp \
        'aco-keyhole: transformed 0 slice compare\(s\), 0 generic memcmp call\(s\), and [1-9][0-9]* ordered midpoint\(s\)' \
        /tmp/aco-redb-midpoint-trace; \
    rm /tmp/aco-redb-midpoint-trace; \
    rm -rf -- "${ACO_CARGO_TARGET_ROOT}"

RUN --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    set -eux; \
    test ! -e "${ACO_CARGO_TARGET_ROOT}"; \
    ACO_OPTIMIZER_TRACE=1 build-redb-benchmark \
        slice-comparison \
        /usr/local/bin/redb-benchmark-slice-comparison \
        2> /tmp/aco-redb-slice-comparison-trace; \
    grep --extended-regexp \
        'aco-keyhole: transformed [1-9][0-9]* slice compare\(s\), [0-9]+ generic memcmp call\(s\), and 0 ordered midpoint\(s\)' \
        /tmp/aco-redb-slice-comparison-trace; \
    rm /tmp/aco-redb-slice-comparison-trace; \
    rm -rf -- "${ACO_CARGO_TARGET_ROOT}"

RUN --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    set -eux; \
    test ! -e "${ACO_CARGO_TARGET_ROOT}"; \
    ACO_OPTIMIZER_TRACE=1 build-redb-benchmark \
        key-comparisons \
        /usr/local/bin/redb-benchmark-key-comparisons \
        2> /tmp/aco-redb-key-comparisons-trace; \
    grep --extended-regexp \
        'aco-keyhole: transformed [1-9][0-9]* slice compare\(s\)' \
        /tmp/aco-redb-key-comparisons-trace; \
    grep --extended-regexp \
        'and [1-9][0-9]* ordered midpoint\(s\)' \
        /tmp/aco-redb-key-comparisons-trace; \
    rm /tmp/aco-redb-key-comparisons-trace; \
    rm -rf -- "${ACO_CARGO_TARGET_ROOT}"

RUN --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    set -eux; \
    test ! -e "${ACO_CARGO_TARGET_ROOT}"; \
    ACO_OPTIMIZER_TRACE=1 build-redb-benchmark \
        optimized \
        /usr/local/bin/redb-benchmark-optimized \
        2> /tmp/aco-redb-optimizer-trace; \
    grep --extended-regexp \
        'aco-three-way-compare: transformed [1-9][0-9]* switch\(es\)' \
        /tmp/aco-redb-optimizer-trace; \
    ! grep --quiet --fixed-strings 'aco-keyhole:' /tmp/aco-redb-optimizer-trace; \
    rm /tmp/aco-redb-optimizer-trace; \
    rm -rf -- "${ACO_CARGO_TARGET_ROOT}"

RUN set -eux; \
    summarize-redb-build-metrics "${ACO_BUILD_METRICS_FILE}" \
        > /usr/local/share/ai-compiler-optimizer/redb-build-metrics-summary.tsv; \
    ACO_BENCHMARK_CANDIDATE_VARIANT=midpoint \
    ACO_OPTIMIZER_PIPELINE_NAME=aco-midpoint-only \
    ACO_OPTIMIZED_BENCHMARK=/usr/local/bin/redb-benchmark-midpoint \
        write-benchmark-provenance \
            /usr/local/share/ai-compiler-optimizer/benchmark-provenance-midpoint.tsv; \
    ACO_BENCHMARK_CANDIDATE_VARIANT=slice-comparison \
    ACO_OPTIMIZER_PIPELINE_NAME=aco-slice-comparison-only \
    ACO_OPTIMIZED_BENCHMARK=/usr/local/bin/redb-benchmark-slice-comparison \
        write-benchmark-provenance \
            /usr/local/share/ai-compiler-optimizer/benchmark-provenance-slice-comparison.tsv; \
    ACO_BENCHMARK_CANDIDATE_VARIANT=key-comparisons \
    ACO_OPTIMIZER_PIPELINE_NAME=aco-key-comparisons \
    ACO_OPTIMIZED_BENCHMARK=/usr/local/bin/redb-benchmark-key-comparisons \
        write-benchmark-provenance \
            /usr/local/share/ai-compiler-optimizer/benchmark-provenance-key-comparisons.tsv; \
    write-benchmark-provenance \
        /usr/local/share/ai-compiler-optimizer/benchmark-provenance-optimized.tsv; \
    cp \
        /usr/local/share/ai-compiler-optimizer/benchmark-provenance-optimized.tsv \
        /usr/local/share/ai-compiler-optimizer/benchmark-provenance.tsv

FROM pinned-bookworm AS redb-benchmark

ARG RUST_IMAGE
ARG RUST_COMMIT
ARG REDB_COMMIT
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

LABEL org.opencontainers.image.title="redb A/B compiler benchmark" \
      org.opencontainers.image.description="Paired redb 4.1.0 benchmarks built by Rust 1.97.1 without and with ACO optimization passes" \
      org.opencontainers.image.source="https://github.com/cberner-ai-org/ai-compiler-optimizer" \
      org.opencontainers.image.base.name="${RUST_IMAGE}" \
      org.cberner-ai.ai-compiler-optimizer.rust-commit="${RUST_COMMIT}" \
      org.cberner-ai.ai-compiler-optimizer.redb-commit="${REDB_COMMIT}" \
      org.cberner-ai.ai-compiler-optimizer.debian-snapshot="${DEBIAN_SNAPSHOT}" \
      org.cberner-ai.ai-compiler-optimizer.build-environment-id="${BUILD_ENVIRONMENT_ID}"

COPY --from=redb-builder \
    /usr/local/bin/redb-benchmark-baseline \
    /usr/local/bin/redb-benchmark-baseline
COPY --from=redb-builder \
    /usr/local/bin/redb-benchmark-optimized \
    /usr/local/bin/redb-benchmark-optimized
COPY --from=redb-builder \
    /usr/local/bin/redb-benchmark-midpoint \
    /usr/local/bin/redb-benchmark-midpoint
COPY --from=redb-builder \
    /usr/local/bin/redb-benchmark-slice-comparison \
    /usr/local/bin/redb-benchmark-slice-comparison
COPY --from=redb-builder \
    /usr/local/bin/redb-benchmark-key-comparisons \
    /usr/local/bin/redb-benchmark-key-comparisons
COPY --from=redb-builder \
    /usr/local/bin/aco-monotonic-clock \
    /usr/local/bin/aco-monotonic-clock
COPY --from=redb-builder \
    /usr/local/share/ai-compiler-optimizer/ \
    /usr/local/share/ai-compiler-optimizer/
COPY --from=redb-builder \
    /usr/local/bin/compare-redb-benchmarks \
    /usr/local/bin/compare-redb-benchmarks
COPY --from=redb-builder \
    /usr/local/bin/select-redb-benchmark-mode \
    /usr/local/bin/select-redb-benchmark-mode

WORKDIR /benchmark
RUN set -eux; \
    test -s /usr/local/share/ai-compiler-optimizer/benchmark-provenance.tsv; \
    /usr/local/bin/aco-monotonic-clock | grep --extended-regexp '^[0-9]+$'; \
    ldd /usr/local/bin/redb-benchmark-baseline; \
    for mode in optimized midpoint slice-comparison key-comparisons; do \
        ldd "/usr/local/bin/redb-benchmark-${mode}"; \
        if ACO_BENCHMARK_MODE="${mode}" ACO_BENCHMARK_RUNS=0 \
            /usr/local/bin/select-redb-benchmark-mode \
            > "/tmp/${mode}-selector-smoke" 2>&1; then \
            exit 1; \
        fi; \
        grep --fixed-strings \
            'ACO_BENCHMARK_RUNS must be a positive integer' \
            "/tmp/${mode}-selector-smoke"; \
        rm "/tmp/${mode}-selector-smoke"; \
    done

CMD ["/usr/local/bin/select-redb-benchmark-mode"]
