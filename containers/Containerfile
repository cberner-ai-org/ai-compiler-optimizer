ARG RUST_IMAGE=docker.io/library/rust:1.97.1-bookworm@sha256:77fac8b98f9f46062bb680b6d25d5bcaabfc400143952ebc572e924bcbedc3fa
ARG RUST_VERSION=1.97.1
ARG RUST_COMMIT=8bab26f4f68e0e26f0bb7960be334d5b520ea452
ARG DEBIAN_SNAPSHOT=20260713T000000Z
ARG BUILD_ENVIRONMENT_ID=857daf7a274f92fd8270b010e8856b4d1ea32c2e0fd3e1d9c012a9f3d623dab1

FROM ${RUST_IMAGE} AS rustc-builder

ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

RUN sed --in-place \
        -e "s|^URIs: http://deb.debian.org/debian$|URIs: http://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT}|" \
        -e "s|^URIs: http://deb.debian.org/debian-security$|URIs: http://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT}|" \
        /etc/apt/sources.list.d/debian.sources \
    && grep --quiet --fixed-strings \
        "URIs: http://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT}" \
        /etc/apt/sources.list.d/debian.sources \
    && grep --quiet --fixed-strings \
        "URIs: http://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT}" \
        /etc/apt/sources.list.d/debian.sources \
    && ! grep --quiet --fixed-strings \
        'URIs: http://deb.debian.org/' \
        /etc/apt/sources.list.d/debian.sources \
    && apt-get -o Acquire::Check-Valid-Until=false update \
    && apt-get install --yes --no-install-recommends \
        cmake \
        ninja-build \
        python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/rust
COPY third_party/rust/ ./
COPY config/rust-git-commit-info ./git-commit-info
COPY config/rust-bootstrap.toml /etc/rust-bootstrap.toml
COPY optimizer/ /usr/src/optimizer/

# Mutable build outputs are scoped to the pinned native environment. The Cargo
# registry remains shared because locked crate downloads are checksum-verified.
RUN --mount=type=cache,id=ai-compiler-optimizer-rust-${BUILD_ENVIRONMENT_ID},target=/usr/src/rust/build \
    --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    set -eux; \
    rustc_source_id="$({ \
        printf 'build-environment:%s\n' "${BUILD_ENVIRONMENT_ID}"; \
        find . -path ./build -prune -o -type f -print0 \
            | LC_ALL=C sort -z \
            | xargs -0 -r sha256sum; \
        sha256sum /etc/rust-bootstrap.toml; \
    } | sha256sum | cut -d ' ' -f 1)"; \
    rustc_source_id_short="$(printf '%s' "${rustc_source_id}" | cut -c1-16)"; \
    ./x build \
        --config /etc/rust-bootstrap.toml \
        --set "build.description=ai-compiler-optimizer-${rustc_source_id_short}" \
        --stage 1 \
        library; \
    build_host="$(rustc --version --verbose | sed -n 's/^host: //p')"; \
    mkdir -p /opt/rust-custom; \
    cp -a "build/${build_host}/stage1/." /opt/rust-custom/; \
    LLVM_CONFIG="build/${build_host}/ci-llvm/bin/llvm-config" \
        OUTPUT=/tmp/libaco_keyhole_pass.so \
        /usr/src/optimizer/build.sh; \
    install --mode 0755 \
        /tmp/libaco_keyhole_pass.so \
        /opt/rust-custom/lib/libaco_keyhole_pass.so; \
    compiler_build_id="$({ \
        printf 'rustc:%s\n' "${rustc_source_id}"; \
        sha256sum /opt/rust-custom/lib/libaco_keyhole_pass.so; \
    } | sha256sum | cut -d ' ' -f 1)"; \
    printf '%s\n' "${compiler_build_id}" > /opt/rust-custom/.compiler-build-id

FROM ${RUST_IMAGE} AS toolchain

ARG RUST_IMAGE
ARG RUST_VERSION
ARG RUST_COMMIT
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

LABEL org.opencontainers.image.title="AI compiler optimizer custom Rust toolchain" \
      org.opencontainers.image.description="Stage-1 Rust 1.97.1 compiler with the ACO no-op keyhole pass" \
      org.opencontainers.image.base.name="${RUST_IMAGE}" \
      org.cberner-ai.ai-compiler-optimizer.debian-snapshot="${DEBIAN_SNAPSHOT}" \
      org.cberner-ai.ai-compiler-optimizer.build-environment-id="${BUILD_ENVIRONMENT_ID}"

COPY --from=rustc-builder /opt/rust-custom/ /opt/rust-custom/
COPY scripts/with-custom-toolchain.sh /usr/local/bin/with-custom-toolchain
COPY scripts/rustc-with-keyhole.sh /usr/local/bin/rustc-with-keyhole
COPY tests/compiler-cache-regression.sh /usr/local/bin/compiler-cache-regression
COPY tests/compiler-cache-probe/ /opt/compiler-cache-probe/
COPY tests/toolchain_smoke.rs /tmp/toolchain_smoke.rs

ENV PATH="/opt/rust-custom/bin:/usr/local/cargo/bin:${PATH}" \
    RUSTC=/usr/local/bin/rustc-with-keyhole \
    RUSTUP_TOOLCHAIN=${RUST_VERSION}

RUN set -eux; \
    test -s /opt/rust-custom/.compiler-build-id; \
    test -s /opt/rust-custom/lib/libaco_keyhole_pass.so; \
    test "$("${RUSTC}" --print sysroot)" = "/opt/rust-custom"; \
    "${RUSTC}" --version | grep --fixed-strings "ai-compiler-optimizer"; \
    "${RUSTC}" --version --verbose; \
    "${RUSTC}" --version --verbose | grep --fixed-strings "commit-hash: ${RUST_COMMIT}"; \
    ACO_KEYHOLE_TRACE=1 "${RUSTC}" \
        --edition 2024 \
        -O \
        /tmp/toolchain_smoke.rs \
        -o /tmp/toolchain-smoke \
        2> /tmp/aco-keyhole-trace; \
    grep --fixed-strings "aco-keyhole: ran on" /tmp/aco-keyhole-trace; \
    /tmp/toolchain-smoke; \
    rm /tmp/aco-keyhole-trace /tmp/toolchain-smoke /tmp/toolchain_smoke.rs

# Cargo must remain fresh for unchanged inputs, but touching the compiler,
# driver, or plugin must alter the Cargo fingerprint.
RUN compiler-cache-regression

CMD ["/usr/local/bin/rustc-with-keyhole", "--version", "--verbose"]

FROM toolchain AS redb-builder

ARG RUST_VERSION
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

RUN sed --in-place \
        -e "s|^URIs: http://deb.debian.org/debian$|URIs: http://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT}|" \
        -e "s|^URIs: http://deb.debian.org/debian-security$|URIs: http://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT}|" \
        /etc/apt/sources.list.d/debian.sources \
    && grep --quiet --fixed-strings \
        "URIs: http://snapshot.debian.org/archive/debian/${DEBIAN_SNAPSHOT}" \
        /etc/apt/sources.list.d/debian.sources \
    && grep --quiet --fixed-strings \
        "URIs: http://snapshot.debian.org/archive/debian-security/${DEBIAN_SNAPSHOT}" \
        /etc/apt/sources.list.d/debian.sources \
    && ! grep --quiet --fixed-strings \
        'URIs: http://deb.debian.org/' \
        /etc/apt/sources.list.d/debian.sources \
    && apt-get -o Acquire::Check-Valid-Until=false update \
    && apt-get install --yes --no-install-recommends \
        cmake \
        libclang-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/redb
COPY third_party/redb/ ./
COPY config/redb-Cargo.lock ./Cargo.lock
COPY scripts/select-cargo-executable.sh /usr/local/bin/select-cargo-executable
COPY scripts/build-redb-benchmark.sh /usr/local/bin/build-redb-benchmark

# Compile and test with the custom rustc. Cargo comes from the pinned official
# image and is only the build orchestrator. The wrapper binds Cargo's artifact
# fingerprint to the copied compiler before each invocation.
RUN --mount=type=cache,id=ai-compiler-optimizer-cargo-registry,target=/usr/local/cargo/registry \
    --mount=type=cache,id=ai-compiler-optimizer-redb-target-${BUILD_ENVIRONMENT_ID},target=/usr/src/redb/target \
    set -eux; \
    test "$("${RUSTC}" --print sysroot)" = "/opt/rust-custom"; \
    cargo --version | grep --fixed-strings "cargo ${RUST_VERSION}"; \
    with-custom-toolchain cargo test --locked --package redb@4.1.0 --lib; \
    build-redb-benchmark

FROM toolchain AS redb-benchmark

ARG RUST_IMAGE
ARG DEBIAN_SNAPSHOT
ARG BUILD_ENVIRONMENT_ID

LABEL org.opencontainers.image.title="redb benchmark with custom Rust compiler" \
      org.opencontainers.image.description="redb 4.1.0 benchmark built by Rust 1.97.1 with the ACO no-op keyhole pass" \
      org.opencontainers.image.base.name="${RUST_IMAGE}" \
      org.cberner-ai.ai-compiler-optimizer.debian-snapshot="${DEBIAN_SNAPSHOT}" \
      org.cberner-ai.ai-compiler-optimizer.build-environment-id="${BUILD_ENVIRONMENT_ID}"

COPY --from=redb-builder /usr/local/bin/redb-benchmark /usr/local/bin/redb-benchmark

WORKDIR /benchmark
RUN ldd /usr/local/bin/redb-benchmark

CMD ["/usr/local/bin/redb-benchmark"]
